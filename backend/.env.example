# HelioScout backend configuration
# Copy to .env and adjust as needed. .env is gitignored — never commit real secrets.

# Port the Express server listens on (Railway injects this automatically in prod)
PORT=3000

# ---------------------------------------------------------------------------
# Proprietary / third-party API keys go HERE (backend/server-side only).
# These are read via process.env and used by the server when calling external
# APIs, then results are proxied to the frontend. Keys never reach the browser.
#
# In production set these in the Railway dashboard (Service -> Variables), NOT
# in Vercel — Vercel/front-end variables are public and shipped to the browser.
#
# Example:
# COMMERCIAL_DATA_API_KEY=your-secret-key-here
# SOME_VENDOR_TOKEN=your-token-here
# ---------------------------------------------------------------------------
