{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "frontend", "-l", "8080"],
      "port": 8080
    },
    {
      "name": "backend",
      "runtimeExecutable": "node",
      "runtimeArgs": ["server.js"],
      "cwd": "backend",
      "port": 3000,
      "env": {
        "JWT_SECRET": "dev-secret",
        "PORT": "3000"
      }
    }
  ]
}
